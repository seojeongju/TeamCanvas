JWT_SECRET=dev-secret-change-in-production
ALLOW_DEV_AUTH=true
APP_URL=http://localhost:8788
FRONTEND_URL=http://localhost:5173

# Resend (https://resend.com) — 프로덕션 이메일 발송
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=TeamCanvas <noreply@yourdomain.com>

# OAuth — Redirect URI (로그인): {APP_URL}/auth/callback/google|kakao
# Google 캘린더 연동 callback: {APP_URL}/api/integrations/google-calendar/callback
# APP_URL=http://127.0.0.1:8788
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# Stripe (구독 결제)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# subscription_plans.stripe_price_monthly_id 에 Stripe Price ID 설정
# PAYMENT_PROVIDER=stripe
# 로컬/스테이징에서 PG 없이 검증하려면 mock 사용:
# PAYMENT_PROVIDER=mock
